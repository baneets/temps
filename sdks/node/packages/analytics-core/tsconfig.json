{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "dist",
		"declaration": false,
		"noEmit": false,
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"verbatimModuleSyntax": false
	},
	"include": ["src"],
	"exclude": ["src/__tests__", "**/*.test.ts"]
}
