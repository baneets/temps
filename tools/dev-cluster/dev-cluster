#!/usr/bin/env bash
#
# Local 3-worker Temps cluster for distributed development.
#
# Usage:
#   ./dev-cluster up          bring everything up
#   ./dev-cluster down        stop services (data persisted in volumes)
#   ./dev-cluster reset       stop and DELETE volumes (fresh slate)
#   ./dev-cluster status      show node + overlay state across the cluster
#   ./dev-cluster logs <svc>  tail logs for a specific service
#   ./dev-cluster shell <svc> open a bash shell inside a service container
#   ./dev-cluster restart <svc>  bounce a single service (worker rebuilds binary)
#
#   svc ∈ { control-plane, worker-1, worker-2, worker-3, postgres }

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE=(docker compose -f "$HERE/docker-compose.yml")
STATE_DIR="$HERE/.state"

green()  { printf '\033[1;32m%s\033[0m' "$*"; }
yellow() { printf '\033[1;33m%s\033[0m' "$*"; }
cyan()   { printf '\033[1;36m%s\033[0m' "$*"; }
red()    { printf '\033[1;31m%s\033[0m' "$*"; }
log()    { printf '%s %s\n' "$(cyan '[dev-cluster]')" "$*"; }
fail()   { printf '%s %s\n' "$(red '[dev-cluster]')"  "$*" >&2; exit 1; }

require_docker() {
  docker version >/dev/null 2>&1 || fail "docker daemon is not running. Start Docker Desktop and retry."
}

cmd_up() {
  require_docker
  mkdir -p "$STATE_DIR"
  log "building dind image (first run only — cached after that)"
  "${COMPOSE[@]}" build

  # Pre-warm the workspace target/ + cargo registry cache by running
  # one cargo build inside a one-shot container that shares the named
  # volumes. This trades 5–10 min of silent wait inside the
  # control-plane healthcheck for 5–10 min of visible cargo output the
  # user can actually monitor. Subsequent `up` runs noop in <2s.
  if [[ "${SKIP_PREBUILD:-0}" != "1" ]]; then
    log "pre-warming cargo cache (set SKIP_PREBUILD=1 to skip)"
    log "  ↳ first run takes 5–10 min; rebuilds are seconds"
    "${COMPOSE[@]}" run --rm --entrypoint='' control-plane \
      bash -c 'cd /workspace && cargo build --bin temps' \
      || fail "prebuild failed (see error above). \
fix the build error, then re-run \`./dev-cluster up\` (or run with SKIP_PREBUILD=1 to defer the build until each container starts)."
  fi

  log "starting cluster"
  "${COMPOSE[@]}" up -d

  # First boot has to compile the temps workspace inside the container
  # (5–10 min on a clean target/). Cap at 20 min so the user knows
  # something is wrong if it really did hang. We also tail the
  # control-plane logs in the background so they can see progress.
  log "waiting for control plane (TCP listen on 127.0.0.1:8080)"
  log "first boot compiles the workspace inside the container — ~5-10 min on a clean cache."
  log "follow progress: ./dev-cluster logs control-plane"
  local elapsed=0
  while ! (echo > /dev/tcp/127.0.0.1/8080) 2>/dev/null; do
    if (( elapsed >= 1200 )); then
      log "$(red 'control plane never came up after 20 min — dumping last 80 log lines:')"
      "${COMPOSE[@]}" logs --tail=80 control-plane >&2 || true
      fail "give up; check the logs above for the build error"
    fi
    if (( elapsed % 30 == 0 )) && (( elapsed > 0 )); then
      log "still waiting (${elapsed}s elapsed, build typically takes 300-600s on first run)"
    fi
    sleep 5
    elapsed=$((elapsed + 5))
  done
  log "control plane is listening"

  # Workers each (re)build the binary too, but they share the cargo
  # cache + target/ volume with the control plane, so once the control
  # plane finishes its build the workers' builds are near-instant.
  log "waiting for all 3 workers to register"
  elapsed=0
  while [[ "$(worker_registered_count)" != "3" ]]; do
    if (( elapsed >= 600 )); then
      local n
      n="$(worker_registered_count)"
      log "$(red "only $n/3 workers registered after 10 min")"
      "${COMPOSE[@]}" logs --tail=40 worker-1 worker-2 worker-3 >&2 || true
      fail "give up; check the logs above"
    fi
    sleep 3
    elapsed=$((elapsed + 3))
  done

  log "waiting for compute_cidr allocation on every worker"
  elapsed=0
  while [[ "$(workers_with_cidr_count)" != "3" ]]; do
    if (( elapsed >= 120 )); then
      log "$(red 'allocator never assigned cidrs to all workers after 2 min')"
      fail "check ./dev-cluster logs control-plane for allocator errors"
    fi
    sleep 2
    elapsed=$((elapsed + 2))
  done

  echo
  printf '%s\n' "$(green '✅ cluster ready')"
  printf '   web UI:        http://localhost:8080\n'
  if [[ -f "$STATE_DIR/admin.txt" ]]; then
    local email pass
    email="$(sed -n 1p "$STATE_DIR/admin.txt")"
    pass="$(sed -n 2p "$STATE_DIR/admin.txt")"
    printf '   admin login:   %s / %s\n' "$email" "$pass"
  fi
  printf '   join token:    %s\n' "${STATE_DIR#$HERE/}/join_token.txt"
  printf '   workers:       worker-1 (10.42.0.21), worker-2 (10.42.0.22), worker-3 (10.42.0.23)\n'
  echo
  cmd_status
}

cmd_down() {
  require_docker
  log "stopping cluster (data preserved in volumes)"
  "${COMPOSE[@]}" down
}

cmd_reset() {
  require_docker
  printf '%s This will DELETE postgres data, all worker docker volumes, and admin credentials. ' "$(yellow 'WARNING:')"
  read -r -p "Continue? [y/N] " ans
  if [[ "$ans" != "y" && "$ans" != "Y" ]]; then
    log "aborted"; return
  fi
  "${COMPOSE[@]}" down -v
  rm -rf "$STATE_DIR"
  log "cluster destroyed"
}

cmd_logs() {
  require_docker
  local svc="${1:-}"
  if [[ -z "$svc" ]]; then
    "${COMPOSE[@]}" logs -f --tail=100
  else
    "${COMPOSE[@]}" logs -f --tail=200 "$svc"
  fi
}

cmd_shell() {
  require_docker
  local svc="${1:?usage: dev-cluster shell <service>}"
  "${COMPOSE[@]}" exec "$svc" bash
}

cmd_restart() {
  require_docker
  local svc="${1:?usage: dev-cluster restart <service>}"
  "${COMPOSE[@]}" restart "$svc"
}

cmd_status() {
  require_docker
  printf '%s\n' "$(cyan '— containers —')"
  "${COMPOSE[@]}" ps --format 'table {{.Name}}\t{{.Status}}\t{{.Ports}}'
  echo
  printf '%s\n' "$(cyan '— allocator state (from postgres) —')"
  if "${COMPOSE[@]}" exec -T postgres psql -U temps -d temps -c "
      SELECT id, name, status, private_address, compute_cidr, underlay_address
        FROM nodes ORDER BY id
    " 2>/dev/null; then :; else
    log "postgres not ready yet"
  fi
  echo
  printf '%s\n' "$(cyan '— overlay state on each worker —')"
  for w in worker-1 worker-2 worker-3; do
    printf '  %s\n' "$(yellow "[$w]")"
    "${COMPOSE[@]}" exec -T "$w" sh -c '
      ip -br link show br-temps0 2>/dev/null || echo "  bridge not present"
      ip -br link show vxlan-temps0 2>/dev/null || echo "  vxlan not present"
      bridge fdb show dev vxlan-temps0 2>/dev/null | head -5 || true
    ' 2>/dev/null | sed "s/^/    /"
  done
}

# ---- helpers ----

worker_registered_count() {
  "${COMPOSE[@]}" exec -T postgres psql -U temps -d temps -tAc \
    "SELECT count(*) FROM nodes WHERE name LIKE 'worker-%'" 2>/dev/null \
    | tr -d '[:space:]' || echo 0
}

workers_with_cidr_count() {
  "${COMPOSE[@]}" exec -T postgres psql -U temps -d temps -tAc \
    "SELECT count(*) FROM nodes WHERE compute_cidr IS NOT NULL" 2>/dev/null \
    | tr -d '[:space:]' || echo 0
}

# ---- dispatch ----

usage() {
  sed -n '3,18p' "$0"
}

case "${1:-}" in
  up)       shift; cmd_up "$@" ;;
  down)     shift; cmd_down "$@" ;;
  reset)    shift; cmd_reset "$@" ;;
  status)   shift; cmd_status "$@" ;;
  logs)     shift; cmd_logs "$@" ;;
  shell)    shift; cmd_shell "$@" ;;
  restart)  shift; cmd_restart "$@" ;;
  ""|-h|--help) usage ;;
  *)        usage; exit 1 ;;
esac
